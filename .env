# ============================================================
# NetverseIQ Environment Configuration
# Copy this file to .env and update values before deploying
# ============================================================

# Application
APP_NAME=NetverseIQ
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=netverseiq-secret-key-2024

# Database (PostgreSQL)
DB_USER=netverseiq
DB_PASSWORD=netverseiq_secret
DB_NAME=netverseiq
DATABASE_URL=postgresql+asyncpg://netverseiq:netverseiq_secret@db:5432/netverseiq

# Redis
REDIS_URL=redis://redis:6379/0

# JWT Tokens
JWT_SECRET_KEY=netverseiq-jwt-secret-2024
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (comma-separated origins)

# Default Admin User (created on first boot)
ADMIN_EMAIL=admin@netverseiq.local
ADMIN_PASSWORD=Admin1234
ADMIN_NAME=System Admin

# Plugin directory (inside container)
PLUGINS_DIR=/app/plugins
